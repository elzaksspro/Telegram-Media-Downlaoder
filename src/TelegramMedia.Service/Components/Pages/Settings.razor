@page "/settings"
@using Microsoft.EntityFrameworkCore
@using TelegramMedia.Core.Data
@using TelegramMedia.Core.Enums
@using TelegramMedia.Core.Interfaces
@inject AppDbContext Db
@inject ITelegramClientService TelegramClient
@inject IDownloadManager DownloadManager
@implements IDisposable

<h1>Settings</h1>

@if (_settings == null)
{
    <p>Loading...</p>
}
else
{
    @if (!string.IsNullOrEmpty(_message))
    {
        <div class="alert @(_isError ? "alert-danger" : "alert-success")">@_message</div>
    }

    <!-- API Credentials -->
    <div class="card">
        <h3>Telegram API Credentials</h3>
        <p style="font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 16px;">
            Get your credentials from <a href="https://my.telegram.org/apps" target="_blank" style="color: var(--accent);">my.telegram.org/apps</a>
        </p>
        <div class="inline-form">
            <div class="form-group">
                <label>API ID</label>
                <input class="form-control" type="number" @bind="_settings.ApiId" />
            </div>
            <div class="form-group">
                <label>API Hash</label>
                <input class="form-control" type="text" @bind="_settings.ApiHash" />
            </div>
        </div>
    </div>

    <!-- Telegram Connection -->
    <div class="card">
        <h3>Telegram Connection</h3>

        @if (!string.IsNullOrEmpty(_authMessage))
        {
            <div class="alert @(_authMessage.Contains("Error", StringComparison.OrdinalIgnoreCase) || _authMessage.Contains("fail", StringComparison.OrdinalIgnoreCase) ? "alert-danger" : "alert-info")">
                @_authMessage
            </div>
        }

        @if (TelegramClient.AuthState == AuthState.Authenticated)
        {
            <div class="alert alert-success" style="margin-bottom:12px;">✓ Connected to Telegram.</div>
            <button class="btn btn-danger" @onclick="Disconnect">Disconnect &amp; Logout</button>
        }
        else if (_authStep == "code")
        {
            <p style="font-size:0.85rem; color:var(--text-secondary); margin-bottom:12px;">
                Enter the verification code Telegram just sent you.
            </p>
            <div class="form-group">
                <label>Verification Code</label>
                <input class="form-control" type="text" @bind="_code"
                       placeholder="12345" style="letter-spacing:6px; font-weight:700; max-width:220px;" />
            </div>
            <button class="btn btn-primary" @onclick="SubmitCode" disabled="@_isConnecting">
                @(_isConnecting ? "Verifying…" : "Verify Code")
            </button>
            <button class="btn btn-secondary" style="margin-left:8px;" @onclick="ResetAuth">Start over</button>
        }
        else if (_authStep == "password")
        {
            <p style="font-size:0.85rem; color:var(--text-secondary); margin-bottom:12px;">
                Your account has two-factor authentication. Enter your 2FA password.
            </p>
            <div class="form-group">
                <label>2FA Password</label>
                <input class="form-control" type="password" @bind="_password" style="max-width:320px;" />
            </div>
            <button class="btn btn-primary" @onclick="SubmitPassword" disabled="@_isConnecting">
                @(_isConnecting ? "Authenticating…" : "Submit Password")
            </button>
            <button class="btn btn-secondary" style="margin-left:8px;" @onclick="ResetAuth">Start over</button>
        }
        else
        {
            <p style="font-size:0.85rem; color:var(--text-secondary); margin-bottom:12px;">
                Make sure your API ID/Hash above are correct, then enter your phone number to sign in.
            </p>
            <div class="form-group">
                <label>Phone Number</label>
                <input class="form-control" type="tel" @bind="_phoneNumber"
                       placeholder="+234 801 234 5678" style="max-width:320px;" />
            </div>
            <button class="btn btn-primary" @onclick="Connect" disabled="@_isConnecting">
                @(_isConnecting ? "Sending…" : "Send Verification Code")
            </button>
        }
    </div>

    <!-- Download Settings -->
    <div class="card">
        <h3>Download Settings</h3>
        <div class="form-group">
            <label>Download Path</label>
            <input class="form-control" type="text" @bind="_settings.DownloadPath" />
        </div>
        <div class="form-group">
            <label>Path Template</label>
            <input class="form-control" type="text" @bind="_settings.PathTemplate" />
            <small style="color: var(--text-secondary); font-size: 0.8rem;">
                Variables: {"{chatType}"}, {"{chatName}"}, {"{mediaType}"}, {"{year}"}, {"{month}"}, {"{day}"}
                — default <code>{"{chatType}"}s/{"{chatName}"}/{"{mediaType}"}</code> groups files by channel/group/user.
            </small>
        </div>
        <div class="inline-form">
            <div class="form-group">
                <label>Max Concurrent Downloads</label>
                <input class="form-control" type="number" min="1" max="10" @bind="_settings.MaxConcurrentDownloads" />
            </div>
            <div class="form-group">
                <label>Max Speed (KB/s, 0 = unlimited)</label>
                <input class="form-control" type="number" min="0" @bind="_settings.MaxSpeedKbps" />
            </div>
        </div>
    </div>

    <!-- Notification Settings -->
    <div class="card">
        <h3>Telegram Notifications</h3>
        <p style="font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 16px;">
            Send download notifications to a Telegram chat via bot.
        </p>
        <div class="toggle-item" style="margin-bottom: 12px;">
            <input type="checkbox" @bind="_settings.SendNotifications" />
            <label>Enable Notifications</label>
        </div>
        @if (_settings.SendNotifications)
        {
            <div class="inline-form">
                <div class="form-group">
                    <label>Bot Token</label>
                    <input class="form-control" type="text" @bind="_settings.NotificationBotToken"
                           placeholder="123456:ABC-DEF1234..." />
                </div>
                <div class="form-group">
                    <label>Chat ID</label>
                    <input class="form-control" type="text" @bind="_settings.NotificationChatId"
                           placeholder="-1001234567890" />
                </div>
            </div>
        }
    </div>

    <!-- Web UI Settings -->
    <div class="card">
        <h3>Web UI</h3>
        <div class="form-group">
            <label>Web Port</label>
            <input class="form-control" type="number" @bind="_settings.WebPort" style="width: 120px;" />
            <small style="color: var(--text-secondary); font-size: 0.8rem;">
                Restart required after changing port.
            </small>
        </div>
    </div>

    <!-- Actions -->
    <div style="display: flex; gap: 12px; margin-top: 20px;">
        <button class="btn btn-primary" @onclick="Save">Save Settings</button>
        <button class="btn btn-secondary" @onclick="Reload">Reload</button>
    </div>
}

@code {
    private AppSettings? _settings;
    private string? _message;
    private bool _isError;

    // Connection flow state
    private string _phoneNumber = "";
    private string _code = "";
    private string _password = "";
    private string _authStep = "phone"; // phone, code, password
    private string? _authMessage;
    private bool _isConnecting;
    private System.Threading.Timer? _authTimer;
    private AuthState _lastAuthState = AuthState.NotAuthenticated;

    protected override async Task OnInitializedAsync()
    {
        _settings = await Db.Settings.FirstOrDefaultAsync();
        TelegramClient.OnStatusMessage += OnAuthStatus;

        // Reflect background auth-state transitions (WaitingForCode/Password/Authenticated).
        _authTimer = new System.Threading.Timer(_ =>
        {
            var s = TelegramClient.AuthState;
            if (s == _lastAuthState) return;
            _lastAuthState = s;
            if (s == AuthState.WaitingForCode) _authStep = "code";
            else if (s == AuthState.WaitingForPassword) _authStep = "password";
            InvokeAsync(StateHasChanged);
        }, null, 0, 1000);
    }

    private void OnAuthStatus(string message)
    {
        _authMessage = message;
        InvokeAsync(StateHasChanged);
    }

    private async Task Connect()
    {
        if (_settings == null) return;
        _isConnecting = true;
        _authMessage = null;
        try
        {
            await Db.SaveChangesAsync(); // persist API ID/Hash the user entered
            await TelegramClient.ConnectAsync(_settings.ApiId, _settings.ApiHash);

            if (TelegramClient.AuthState == AuthState.Authenticated)
            {
                _authMessage = "Already connected.";
            }
            else
            {
                await TelegramClient.SendCodeAsync(_phoneNumber);
                _authMessage = "Verification code sent to your Telegram app.";
                _authStep = "code";
            }
        }
        catch (Exception ex)
        {
            _authMessage = $"Error: {ex.Message}";
        }
        _isConnecting = false;
    }

    private async Task SubmitCode()
    {
        _isConnecting = true;
        try
        {
            await TelegramClient.SubmitCodeAsync(_code);
            _authMessage = "Verifying…";
            for (var i = 0; i < 20; i++)
            {
                await Task.Delay(500);
                if (TelegramClient.AuthState == AuthState.Authenticated) { _authMessage = "Connected."; break; }
                if (TelegramClient.AuthState == AuthState.WaitingForPassword) { _authStep = "password"; _authMessage = "2FA password required."; break; }
            }
        }
        catch (Exception ex) { _authMessage = $"Error: {ex.Message}"; }
        _isConnecting = false;
    }

    private async Task SubmitPassword()
    {
        _isConnecting = true;
        try
        {
            await TelegramClient.SubmitPasswordAsync(_password);
            _authMessage = "Authenticating…";
            for (var i = 0; i < 20; i++)
            {
                await Task.Delay(500);
                if (TelegramClient.AuthState == AuthState.Authenticated) { _authMessage = "Connected."; break; }
            }
        }
        catch (Exception ex) { _authMessage = $"Error: {ex.Message}"; }
        _isConnecting = false;
    }

    private async Task ResetAuth()
    {
        await TelegramClient.DisconnectAsync();
        _authStep = "phone";
        _code = "";
        _password = "";
        _authMessage = null;
    }

    public void Dispose()
    {
        TelegramClient.OnStatusMessage -= OnAuthStatus;
        _authTimer?.Dispose();
    }

    private async Task Save()
    {
        if (_settings == null) return;
        try
        {
            await Db.SaveChangesAsync();
            // Apply queue limits live so no restart is needed.
            await DownloadManager.SetMaxConcurrentAsync(_settings.MaxConcurrentDownloads);
            await DownloadManager.SetBandwidthLimitAsync(_settings.MaxSpeedKbps);
            _message = "Settings saved successfully.";
            _isError = false;
        }
        catch (Exception ex)
        {
            _message = $"Error saving: {ex.Message}";
            _isError = true;
        }
    }

    private async Task Reload()
    {
        _settings = await Db.Settings.FirstOrDefaultAsync();
        _message = null;
    }

    private async Task Disconnect()
    {
        await TelegramClient.DisconnectAsync();
        _authStep = "phone";
        _code = "";
        _password = "";
        _authMessage = null;
        _message = "Disconnected. Session cleared.";
        _isError = false;
    }
}
