@inherits LayoutComponentBase

<div class="app-container">
    <nav class="sidebar">
        <div class="sidebar-header">
            <div class="logo-icon" style="background:none;">
                <img src="logo.svg" alt="logo" width="36" height="36" />
            </div>
            <h2>Telegram Downloader</h2>
        </div>
        <ul class="nav-menu">
            <li class="@GetNavClass("/")">
                <a href="/">
                    <span class="nav-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
                        </svg>
                    </span>
                    <span>Dashboard</span>
                </a>
            </li>
            <li class="@GetNavClass("/chats")">
                <a href="/chats">
                    <span class="nav-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                        </svg>
                    </span>
                    <span>Chats</span>
                </a>
            </li>
            <li class="@GetNavClass("/settings")">
                <a href="/settings">
                    <span class="nav-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                        </svg>
                    </span>
                    <span>Settings</span>
                </a>
            </li>
        </ul>
        <div class="sidebar-footer">
            <div class="status-indicator @(IsConnected ? "connected" : "disconnected")">
                <span>@(IsConnected ? "Connected" : "Not Connected")</span>
            </div>
        </div>
    </nav>

    <main class="main-content">
        @Body
    </main>
</div>

@code {
    [Inject] private TelegramMedia.Core.Interfaces.ITelegramClientService TelegramClient { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private bool IsConnected => TelegramClient.IsConnected;

    private string GetNavClass(string path)
    {
        var currentUri = Navigation.ToBaseRelativePath(Navigation.Uri);
        if (path == "/") return string.IsNullOrEmpty(currentUri) ? "active" : "";
        return currentUri.StartsWith(path.TrimStart('/')) ? "active" : "";
    }
}
